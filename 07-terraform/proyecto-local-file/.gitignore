# Local .terraform directories
**/.terraform/*

# .tfstate files
*.tfstate
*.tfstate.*

# Crash log files
crash.log
crash.*.log

# Exclude all .tfvars files, which are likely to contain sensitive data
*.tfvars
!terraform.tfvars.example

# Exclude all .tfvars.json files
*.tfvars.json

# Ignore override files, as they are usually used to override resources locally
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Ignore CLI configuration files
.terraformrc
terraform.rc

# Ignore plan files
*.tfplan
plan.out
*.tfplan.json

# Ignore variable definitions files
*.auto.tfvars
*.auto.tfvars.json

# OS specific files
.DS_Store
Thumbs.db
*.swp
*.swo
*~
.vscode/
.idea/

# Archivos creados por este proyecto
archivos/
*.txt

